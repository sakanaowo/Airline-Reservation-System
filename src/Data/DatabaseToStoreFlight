
import java.sql.*;

public class APIForFlight {
    private static final String url = "jdbc:mysql://localhost:3306/AirLineReservation";
    private static final String user = "root";
    private static final String pass = "Khoaptit123.";
    private static Connection con;

    static {
        try {
            con = DriverManager.getConnection(url, user, pass);
        } catch (SQLException e) {
            e.printStackTrace();
        }
    }

    // Thêm chuyến bay
    public static void addFlight(String flightID, String status, String origin, String destination, 
                                 String departureTime, String arrivalTime, float price) throws SQLException {
        String query = "INSERT INTO Flight (flightID, status, origin, destination, departureTime, arrivalTime, price) VALUES (?, ?, ?, ?, ?, ?, ?)";
        try (PreparedStatement stmt = con.prepareStatement(query)) {
            stmt.setString(1, flightID);
            stmt.setString(2, status);
            stmt.setString(3, origin);
            stmt.setString(4, destination);
            stmt.setString(5, departureTime);
            stmt.setString(6, arrivalTime);
            stmt.setFloat(7, price);
            stmt.executeUpdate();
            System.out.println("Flight added successfully!");
        }
    }
    
    //Chỉnh sửa chuyến bay
    public static void updateFlight(String flightID, String status, String origin, String destination, 
                                    String departureTime, String arrivalTime, float price) throws SQLException {
        String query = "UPDATE Flight SET status = ?, origin = ?, destination = ?, departureTime = ?, arrivalTime = ?, price = ? WHERE flightID = ?";
        try (PreparedStatement stmt = con.prepareStatement(query)) {
            stmt.setString(1, status);
            stmt.setString(2, origin);
            stmt.setString(3, destination);
            stmt.setString(4, departureTime);
            stmt.setString(5, arrivalTime);
            stmt.setFloat(6, price);
            stmt.setString(7, flightID);
            stmt.executeUpdate();
            System.out.println("Flight updated successfully!");
        }
    }

    // Xóa chuyến bay thông qua ID
    public static void deleteFlight(String flightID) throws SQLException {
        String query = "DELETE FROM Flight WHERE flightID = ?";
        try (PreparedStatement stmt = con.prepareStatement(query)) {
            stmt.setString(1, flightID);
            stmt.executeUpdate();
            System.out.println("Flight deleted successfully!");
        }
    }

    // Lấy chuyến bay thông qua ID
    public static void getFlight(String flightID) throws SQLException {
        String query = "SELECT * FROM Flight WHERE flightID = ?";
        try (PreparedStatement stmt = con.prepareStatement(query)) {
            stmt.setString(1, flightID);
            try (ResultSet rs = stmt.executeQuery()) {
                if (rs.next()) {
                    System.out.println("FlightID: " + rs.getString("flightID"));
                    System.out.println("Status: " + rs.getString("status"));
                    System.out.println("Origin: " + rs.getString("origin"));
                    System.out.println("Destination: " + rs.getString("destination"));
                    System.out.println("Departure Time: " + rs.getString("departureTime"));
                    System.out.println("Arrival Time: " + rs.getString("arrivalTime"));
                    System.out.println("Price: " + rs.getFloat("price"));
                    System.out.println("Seat Map: " + rs.getString("seatMap"));
                } else {
                    System.out.println("Flight not found.");
                }
            }
        }
    }

    public static void main(String[] args) {
        try {
            // Example usage
            addFlight("FL123", "Scheduled", "Hanoi", "Ho Chi Minh City", "2024-10-22 08:00", "2024-10-22 10:00", 100.0f);
            getFlight("FL123");
            updateFlight("FL123", "Delayed", "Hanoi", "Ho Chi Minh City", "2024-10-22 09:00", "2024-10-22 11:00", 105.0f);
            deleteFlight("FL123");
        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
}

